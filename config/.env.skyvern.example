ENV=local
LOG_LEVEL=INFO

# Keep all cloud providers disabled
ENABLE_OPENAI=false
ENABLE_ANTHROPIC=false
ENABLE_GEMINI=false
ENABLE_AZURE=false
ENABLE_NOVITA=false
ENABLE_VOLCENGINE=false
ENABLE_YUTORI=false

# Local LLM runtime via Ollama
ENABLE_OLLAMA=true
LLM_KEY=OLLAMA
SECONDARY_LLM_KEY=OLLAMA
OLLAMA_MODEL=qwen2.5vl:7b
OLLAMA_SERVER_URL=http://127.0.0.1:11434
OLLAMA_SUPPORTS_VISION=true

# Local browser
BROWSER_TYPE=chromium-headless

